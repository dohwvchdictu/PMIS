# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this to .env for production deployment
# IMPORTANT: Update all values marked with <CHANGE_ME>

APP_NAME=BACPMIS
APP_ENV=production
APP_KEY=<CHANGE_ME_GENERATE_WITH_php_artisan_key:generate>
APP_DEBUG=false
APP_URL=https://bacpmis.doh.gov.ph
APP_TIMEZONE=Asia/Manila

# Logging - Use daily for production
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error
LOG_DAYS=14

# Database Configuration - PRODUCTION
DB_CONNECTION=mysql
DB_HOST=<CHANGE_ME_DATABASE_HOST>
DB_PORT=3306
DB_DATABASE=bacpmis_production
DB_USERNAME=<CHANGE_ME_DATABASE_USER>
DB_PASSWORD=<CHANGE_ME_DATABASE_PASSWORD>

# Cache & Session - Use Redis for production
BROADCAST_DRIVER=redis
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Redis Configuration
REDIS_HOST=<CHANGE_ME_REDIS_HOST>
REDIS_PASSWORD=<CHANGE_ME_REDIS_PASSWORD>
REDIS_PORT=6379

# JWT Configuration - PRODUCTION
JWT_SECRET=<CHANGE_ME_GENERATE_RANDOM_STRING_64_CHARS>
JWT_TTL=300
JWT_REFRESH_THRESHOLD=240

# External API Configuration - PRODUCTION
API_BASE_URL=<CHANGE_ME_API_URL>
API_TIMEOUT=10

# Audit Configuration
AUDIT_ENABLED=true
AUDIT_STRICT=false

# Security - PRODUCTION SETTINGS
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

# Mail Configuration - PRODUCTION
MAIL_MAILER=smtp
MAIL_HOST=<CHANGE_ME_MAIL_HOST>
MAIL_PORT=587
MAIL_USERNAME=<CHANGE_ME_MAIL_USERNAME>
MAIL_PASSWORD=<CHANGE_ME_MAIL_PASSWORD>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@bacpmis.doh.gov.ph"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (if using S3 for file storage)
AWS_ACCESS_KEY_ID=<CHANGE_ME_IF_USING_S3>
AWS_SECRET_ACCESS_KEY=<CHANGE_ME_IF_USING_S3>
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=<CHANGE_ME_IF_USING_S3>
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite Configuration
VITE_APP_NAME="${APP_NAME}"

# ========================================
# SECURITY CHECKLIST FOR PRODUCTION
# ========================================
# [ ] Set APP_DEBUG to false
# [ ] Set APP_ENV to production
# [ ] Generate new APP_KEY
# [ ] Generate new JWT_SECRET
# [ ] Update all database credentials
# [ ] Configure Redis with strong password
# [ ] Enable HTTPS and set SESSION_SECURE_COOKIE=true
# [ ] Configure mail server
# [ ] Set proper file permissions (storage & bootstrap/cache: 775)
# [ ] Configure firewall rules
# [ ] Set up SSL certificate
# [ ] Configure backup strategy
# [ ] Set up monitoring (Laravel Telescope disabled in production)
# [ ] Configure error tracking (Sentry, etc.)
# [ ] Review and update CORS settings if needed
